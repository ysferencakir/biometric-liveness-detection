# Bu dosyayı kopyalayıp .env olarak kaydet, asla Git'e commit etme

# Uygulama
SECRET_KEY=gizli-anahtarini-buraya-yaz
DEBUG=true

# Yüz tanıma eşikleri (opsiyonel, varsayılan değerler kullanılabilir)
FACE_MATCH_THRESHOLD=0.50
CHALLENGE_SUCCESS_RATIO=0.80

# Firebase (şimdilik kullanılmıyor)
# FIREBASE_CREDENTIALS=firebase-credentials.json
# FIRESTORE_PROJECT_ID=proje-id
